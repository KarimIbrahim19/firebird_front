# API Configuration
VITE_API_BASE_URL=http://10.10.20.80:3001/api
VITE_APP_URL=http://10.10.20.80:5173         ##

# WebAuthn Configuration
VITE_WEBAUTHN_RP_NAME=Pharmacy Portal        # Shows up in the biometric prompt
VITE_WEBAUTHN_RP_ID=10.10.20.80              # Must match your domain/IP for biometric authentication to work
VITE_WEBAUTHN_ORIGIN=http://10.10.20.80:5173  ##

# Features Toggle
VITE_ENABLE_BIOMETRIC=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_PWA=true

# Default Settings
VITE_DEFAULT_LANGUAGE=ar                    # Values: ar or en Before user preference is saved
VITE_DEFAULT_THEME=light                    # Values: light or dark Before user preference is saved
VITE_DEFAULT_STORE_ID=1                     # Used in product API calls as default store parameter

# API Timeouts (in milliseconds)
VITE_API_TIMEOUT=30000                      # Change to 45000 ms for slow networks
VITE_API_RETRY_COUNT=3                      # More retries for unreliable connections

# Cache Settings (in seconds)
VITE_CACHE_DURATION=300                     # 5 minutes cache
VITE_OFFLINE_CACHE_DURATION=86400           # 86400 (24 hours) Service worker cache expiration

# Push Notifications
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Sentry (Error Tracking) - Optional
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Google Analytics - Optional
VITE_GA_TRACKING_ID=

# App Information
VITE_APP_NAME=دار الحكمة
VITE_APP_NAME_EN=دار الحكمة
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=بوابة إلكترونية لدار الحكمة
VITE_APP_DESCRIPTION_EN=Dar ElHekma Portal

# Development Settings
VITE_DEV_MODE=true
VITE_SHOW_DEBUG_INFO=true
VITE_MOCK_API=false